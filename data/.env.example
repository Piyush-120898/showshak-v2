# ───────────────────────────────────────────────────────────────
# data/.env.example  —  COMMITTED TEMPLATE (placeholders only)
# ───────────────────────────────────────────────────────────────
# Copy this file to data/.env and fill in REAL values locally.
#   cp data/.env.example data/.env
#
# data/.env is GIT-IGNORED and must NEVER be committed. The TMDB key
# and the Supabase service-role key are local/server-only secrets.
# They must never appear in any showshak-*.js, HTML file, or commit.
#
# Used only by data/ingest-tmdb.js, which runs on the founder's
# TMDB-reachable machine. The shipped browser app never reads these.
# ───────────────────────────────────────────────────────────────

# TMDB v3 API key (the "API Key (v3 auth)" value from your TMDB account)
TMDB_API_KEY=your_tmdb_v3_api_key_here

# Supabase project URL (e.g. https://YOUR-PROJECT.supabase.co)
SUPABASE_URL=https://YOUR-PROJECT.supabase.co

# Supabase SERVICE ROLE key (bypasses RLS — local/server-only, never in the browser)
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
